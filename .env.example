# Environment variables template. Copy to `.env` and fill with real values.
# `.env` is gitignored — never commit real secrets.

# HuggingFace Hub (model storage + registry)
HF_TOKEN=hf_your_token_here
HF_USERNAME=your_username_here

# MLOps WRITE-endpoint auth (upload-batch, retrain, rollback)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
MLOPS_API_KEY=your_random_api_key_here
